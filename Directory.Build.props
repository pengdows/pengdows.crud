<Project>
    <PropertyGroup>
        <!--
          Skip the "no vendor" verification step that checks for vendored dependencies.
          Set to false on CI/build agents where .NET 8 tooling is available.
        -->
        <SkipVerifyNoVendor>true</SkipVerifyNoVendor>
        <!--
          Skip public API interface validation during builds.
          Set to false on CI and release builds to enforce API compatibility checks.
        -->
        <SkipInterfaceValidation>true</SkipInterfaceValidation>
        <Version>2.0.0</Version>
        <InformationalVersion>$(Version)</InformationalVersion>
        <AssemblyVersion>2.0.0.0</AssemblyVersion>
        <FileVersion>2.0.0.0</FileVersion>
    </PropertyGroup>
</Project>
